generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model MembershipApplication {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  status         String

  firstName      String
  lastName       String

  email          String
  phone          String?

  street         String
  zip            String
  city           String

  membershipFee  Float

  paymentMethod  String

  iban           String?
  accountHolder  String?

  message        String?
}

model Admin {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  email     String   @unique
  password  String
  role      String   @default("admin")
}

model Member {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  memberNumber   String   @unique
  status         String   @default("Aktiv")

  firstName      String
  lastName       String
  email          String @unique
  phone          String?

  street         String
  zip            String
  city           String

  membershipFee  Float
  paymentMethod  String

  iban           String?
  accountHolder  String?
  mandateReference String?

  joinedAt       DateTime @default(now())

  password       String?
  lastLogin      DateTime?
  mustChangePassword Boolean  @default(true)

  resetToken       String?
  resetTokenExpiry DateTime?
}

model Donation {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  donorName     String
  donorEmail    String?

  amount        Float

  purpose       String?

  paymentMethod String

  donationDate  DateTime @default(now())

  receiptStatus String @default("Offen")
}

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  title     String
  category  String
  fileUrl   String

  visible   Boolean  @default(true)
}

model SurveyResponse {
  id          String   @id @default(cuid())
  language    String
  name        String?
  rating      Int
  answerOne   String
  answerTwo   String
  createdAt   DateTime @default(now())
}