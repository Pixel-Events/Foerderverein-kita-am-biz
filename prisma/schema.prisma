generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model MembershipApplication {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())

  status         String

  firstName      String
  lastName       String

  email          String
  phone          String?

  street         String
  zip            String
  city           String

  membershipFee  Float

  paymentMethod  String

  iban           String?
  accountHolder  String?

  message        String?
}